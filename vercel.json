{
  "name": "strattonoak",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "functions": {
    "api/health.py": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/analyze.py": {
      "memory": 3008,
      "maxDuration": 900
    }
  },
  "env": {
    "NEXT_PUBLIC_API_URL": "@backend-api-url",
    "BACKEND_URL": "@backend-api-url"
  }
}
